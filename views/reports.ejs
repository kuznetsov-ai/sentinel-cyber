<%
// Bar chart helpers
const maxSev = Math.max(...charts.by_severity.map(d => d.count), 1);
const maxMeth = Math.max(...charts.by_method.map(d => d.count), 1);
const maxTl  = Math.max(...charts.timeline.map(d => d.count), 1);

// Donut helpers (severity)
const totalSev = charts.by_severity.reduce((s, d) => s + d.count, 0);
const sevColors = { Critical:'#ff5352', High:'#f59e0b', Medium:'#b0c6ff', Low:'#4ae183' };
const methColors = { Velocity:'#b0c6ff', 'ML Model':'#4ae183', Pattern:'#f59e0b', Threshold:'#ff5352' };

// Build donut arcs for severity
let arcCursor = 0;
const circumference = 2 * Math.PI * 52;
const sevArcs = charts.by_severity.map(d => {
  const frac = d.count / (totalSev || 1);
  const dash = frac * circumference;
  const offset = -arcCursor * circumference;
  arcCursor += frac;
  return { ...d, dash: dash.toFixed(2), offset: offset.toFixed(2), color: sevColors[d.severity] || '#8c90a1' };
});
%>
<div class="sc-page-header">
  <div>
    <h2>Reports &amp; Analytics</h2>
    <p>Historical fraud analysis and detection metrics</p>
  </div>
  <div style="display:flex;gap:8px;">
    <select class="sc-select">
      <option>Last 24 hours</option>
      <option>Last 7 days</option>
      <option selected>Last 30 days</option>
      <option>Last 90 days</option>
    </select>
    <button class="sc-btn sc-btn-primary"><span class="material-symbols-outlined">download</span>Export PDF</button>
  </div>
</div>

<!-- Row 1: donut + severity bars + method bars -->
<div style="display:grid;grid-template-columns:260px 1fr 1fr;gap:14px;margin-bottom:14px;">

  <!-- Severity donut -->
  <div class="sc-card" style="display:flex;flex-direction:column;align-items:center;gap:12px;">
    <div style="text-align:center;">
      <h3>By Severity</h3>
      <div class="sc-card-sub">Total: <%= totalSev %> alerts</div>
    </div>
    <svg viewBox="0 0 120 120" width="130" height="130">
      <% for (const arc of sevArcs) { %>
      <circle cx="60" cy="60" r="52"
        fill="none"
        stroke="<%= arc.color %>"
        stroke-width="13"
        stroke-dasharray="<%= arc.dash %> <%= circumference.toFixed(2) %>"
        stroke-dashoffset="<%= arc.offset %>"
        transform="rotate(-90 60 60)"
        stroke-linecap="butt"
        opacity="0.85"/>
      <% } %>
      <text x="60" y="56" text-anchor="middle" font-size="15" font-weight="700" fill="var(--text)" font-family="Manrope,sans-serif"><%= totalSev %></text>
      <text x="60" y="70" text-anchor="middle" font-size="9" fill="var(--text-muted)" font-family="Inter,sans-serif">TOTAL</text>
    </svg>
    <div style="display:flex;flex-direction:column;gap:5px;width:100%;">
      <% for (const arc of sevArcs) { %>
      <div style="display:flex;align-items:center;justify-content:space-between;font-size:12px;">
        <div style="display:flex;align-items:center;gap:7px;">
          <div style="width:9px;height:9px;border-radius:2px;background:<%= arc.color %>;flex-shrink:0;"></div>
          <span><%= arc.severity %></span>
        </div>
        <span style="color:var(--text-muted);font-weight:600;"><%= arc.count %></span>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Severity bar chart -->
  <div class="sc-card">
    <h3 style="margin-bottom:16px;">Alerts by Severity</h3>
    <svg viewBox="0 0 320 160" style="width:100%;height:160px;overflow:visible;">
      <% charts.by_severity.forEach((d, i) => {
        const barH = Math.max(4, (d.count / maxSev) * 130);
        const x = 30 + i * 72;
        const y = 140 - barH;
        const col = sevColors[d.severity] || '#8c90a1';
      %>
      <rect x="<%= x %>" y="<%= y.toFixed(1) %>" width="44" height="<%= barH.toFixed(1) %>"
        rx="4" fill="<%= col %>" opacity="0.75"/>
      <text x="<%= x + 22 %>" y="<%= (y - 5).toFixed(1) %>" text-anchor="middle"
        font-size="10" font-weight="700" fill="<%= col %>" font-family="Inter,sans-serif"><%= d.count %></text>
      <text x="<%= x + 22 %>" y="154" text-anchor="middle"
        font-size="9" fill="var(--text-muted)" font-family="Inter,sans-serif"><%= d.severity.slice(0,4) %></text>
      <% }) %>
      <line x1="20" y1="140" x2="310" y2="140" stroke="rgba(66,70,85,0.3)" stroke-width="1"/>
    </svg>
  </div>

  <!-- Detection method bar chart -->
  <div class="sc-card">
    <h3 style="margin-bottom:16px;">Alerts by Detection Method</h3>
    <svg viewBox="0 0 320 160" style="width:100%;height:160px;overflow:visible;">
      <% charts.by_method.forEach((d, i) => {
        const barH = Math.max(4, (d.count / maxMeth) * 130);
        const x = 20 + i * 74;
        const y = 140 - barH;
        const col = methColors[d.method] || '#8c90a1';
      %>
      <rect x="<%= x %>" y="<%= y.toFixed(1) %>" width="48" height="<%= barH.toFixed(1) %>"
        rx="4" fill="<%= col %>" opacity="0.75"/>
      <text x="<%= x + 24 %>" y="<%= (y - 5).toFixed(1) %>" text-anchor="middle"
        font-size="10" font-weight="700" fill="<%= col %>" font-family="Inter,sans-serif"><%= d.count %></text>
      <text x="<%= x + 24 %>" y="154" text-anchor="middle"
        font-size="9" fill="var(--text-muted)" font-family="Inter,sans-serif"><%= d.method.split(' ')[0].slice(0,6) %></text>
      <% }) %>
      <line x1="12" y1="140" x2="310" y2="140" stroke="rgba(66,70,85,0.3)" stroke-width="1"/>
    </svg>
  </div>
</div>

<!-- Row 2: timeline bar chart full width -->
<div class="sc-card" style="margin-bottom:14px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
    <div>
      <h3>Hourly Alert Volume</h3>
      <div class="sc-card-sub">24-hour detection timeline</div>
    </div>
    <span class="sc-badge badge-medium"><%= charts.timeline.reduce((s,d) => s+d.count, 0) %> total</span>
  </div>
  <svg viewBox="0 0 800 130" style="width:100%;height:130px;overflow:visible;">
    <!-- grid -->
    <% [0,1,2,3].forEach(i => {
      const y = 10 + i * 30;
    %>
    <line x1="0" y1="<%= y %>" x2="800" y2="<%= y %>" stroke="rgba(66,70,85,0.15)" stroke-width="1" stroke-dasharray="3,4"/>
    <% }) %>
    <% charts.timeline.forEach((d, i) => {
      const barW = 28;
      const gap  = (800 - 24 * barW) / 25;
      const x    = gap + i * (barW + gap);
      const barH = Math.max(3, (d.count / maxTl) * 100);
      const y    = 110 - barH;
    %>
    <rect x="<%= x.toFixed(1) %>" y="<%= y.toFixed(1) %>" width="<%= barW %>" height="<%= barH.toFixed(1) %>"
      rx="3" fill="var(--primary)" opacity="0.55"/>
    <% if (i % 4 === 0) { %>
    <text x="<%= (x + barW/2).toFixed(1) %>" y="124" text-anchor="middle"
      font-size="9" fill="var(--text-muted)" font-family="Inter,sans-serif"><%= String(d.hour).padStart(2,'0') %>h</text>
    <% } %>
    <% }) %>
    <line x1="0" y1="110" x2="800" y2="110" stroke="rgba(66,70,85,0.3)" stroke-width="1"/>
  </svg>
</div>

<!-- Row 3: summary table -->
<div class="sc-card">
  <h3 style="margin-bottom:14px;">Detection Method Summary</h3>
  <div class="sc-table-wrap">
    <table class="sc-table">
      <thead>
        <tr>
          <th>Method</th>
          <th>Alerts</th>
          <th>Share</th>
          <th>Trend</th>
          <th>Avg Severity</th>
        </tr>
      </thead>
      <tbody>
        <% const totalMeth = charts.by_method.reduce((s,d) => s+d.count, 0); %>
        <% for (const d of charts.by_method) { %>
        <tr>
          <td>
            <% const mc = {
              'Velocity':  'badge-velocity',
              'ML Model':  'badge-ml-model',
              'Pattern':   'badge-pattern',
              'Threshold': 'badge-threshold'
            }[d.method] || 'badge-medium'; %>
            <span class="sc-badge <%= mc %>"><%= d.method %></span>
          </td>
          <td style="font-weight:600;"><%= d.count %></td>
          <td>
            <div style="display:flex;align-items:center;gap:8px;">
              <div style="width:80px;height:5px;background:rgba(66,70,85,0.35);border-radius:3px;overflow:hidden;">
                <div style="width:<%= ((d.count/totalMeth)*100).toFixed(1) %>%;height:100%;background:<%= methColors[d.method] || '#8c90a1' %>;opacity:0.8;border-radius:3px;"></div>
              </div>
              <span class="td-muted"><%= ((d.count/totalMeth)*100).toFixed(0) %>%</span>
            </div>
          </td>
          <td><span style="color:var(--success);font-size:12px;font-weight:600;">&#x2191; +5%</span></td>
          <td><span class="sc-badge badge-medium">Medium</span></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
